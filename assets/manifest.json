{
  "name": "Kyouka",
  "description": "魔法凝结",
  "version": "1.1.0",
  "manifest_version": 3,
  "permissions": [
    "scripting",
    "activeTab",
    "cookies",
    "storage",
    "declarativeNetRequestWithHostAccess",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "/icons/icon128.png"
  },
  "action": {},
  "background": {
    "service_worker": "service.js",
    "type": "module"
  },
  "homepage_url": "https://github.com/NativeStar/Kyouka",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "menu.html",
        "menu.css"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "preload.js"
      ],
      "type": "module",
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "commands": {
    "openPanelHotkey": {
      "suggested_key": "Alt+M",
      "description": "开关控制面板"
    },
    "openWithResetPosition": {
      "suggested_key": "Alt+Shift+M",
      "description": "重置位置并开关控制面板"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "removeCsp",
        "enabled": false,
        "path": "removeCsp.json"
      }
    ]
  }
}